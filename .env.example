# =========================
# CORE APP CONFIG
# =========================
APP_NAME=AAPP-MART
APP_ENV=development
DEBUG=true
LOG_LEVEL=info

# =========================
# SECURITY / AUTH
# =========================
SECRET_KEY=
JWT_SECRET=
JWT_EXPIRATION=3600

# =========================
# DATABASE (Azure Cosmos DB)
# =========================
DB_PROVIDER=cosmos

# =========================
# RED TEAM ENGINE
# =========================
MAX_AGENTS=5
SIMULATION_DEPTH=10
ENABLE_AUTONOMOUS_MODE=true

# =========================
# AI / MODEL CONFIG
# =========================
MODEL_PROVIDER=microsoft
MODEL_NAME=phi-4-reasoning
MODEL_TEMPERATURE=0.3
MODEL_MAX_TOKENS=2048

# Azure OpenAI API Key
AZURE_OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_ID=

# =========================
# THREAT INTELLIGENCE
# =========================
ENABLE_THREAT_FEEDS=true
MITRE_ATTACK_VERSION=14

# =========================
# API SERVER
# =========================
HOST=0.0.0.0
PORT=8000

# =========================
# EXPERIMENTAL FEATURES
# =========================
ENABLE_SELF_LEARNING=false
ENABLE_ATTACK_SIMULATION=true
ENABLE_DEFENSE_MODE=false
