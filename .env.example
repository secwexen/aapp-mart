# =========================
# CORE APP CONFIG
# =========================
APP_NAME=AAPP-MART
APP_ENV=development
DEBUG=true
LOG_LEVEL=info

# =========================
# SECURITY / AUTH
# =========================
SECRET_KEY=change_this_secret
JWT_SECRET=change_this_jwt_secret
JWT_EXPIRATION=3600

# =========================
# DATABASE
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aappmart
DB_USER=sqlserver
DB_PASSWORD=sqlserver

# Optional (SQLite fallback)
SQLITE_PATH=./data/aappmart.db

# =========================
# RED TEAM ENGINE
# =========================
MAX_AGENTS=5
SIMULATION_DEPTH=10
ATTACK_GRAPH_MAX_NODES=1000
ENABLE_AUTONOMOUS_MODE=true

# =========================
# AI / MODEL CONFIG
# =========================
MODEL_PROVIDER=microsoft
MODEL_NAME=phi-4-reasoning
MODEL_TEMPERATURE=0.3
MODEL_MAX_TOKENS=2048

# Azure OpenAI API Key
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Optional: endpoint & deployment
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_ID=your_deployment_id_here

# =========================
# THREAT INTELLIGENCE
# =========================
ENABLE_THREAT_FEEDS=true
MITRE_ATTACK_VERSION=14
RISK_SCORING_MODEL=default

# =========================
# NETWORK / SCANNING
# =========================
DEFAULT_SCAN_TIMEOUT=10
MAX_PORT_SCAN=1000
ENABLE_NMAP=false
NMAP_PATH=/usr/bin/nmap

# =========================
# LOGGING & MONITORING
# =========================
ENABLE_AUDIT_LOG=true
LOG_FILE=./logs/app.log

# =========================
# API SERVER
# =========================
HOST=0.0.0.0
PORT=8000

# =========================
# CACHE
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# =========================
# EXPERIMENTAL FEATURES
# =========================
ENABLE_SELF_LEARNING=false
ENABLE_ATTACK_SIMULATION=true
ENABLE_DEFENSE_MODE=false
